# Supabase (Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Project Settings -> API -> JWT Secret (used to verify user tokens locally)
SUPABASE_JWT_SECRET=your-jwt-secret

# LLM provider: "gemini" (default) or "claude".
# Claude still needs GEMINI_API_KEY set — it embeds with Gemini (RAG).
LLM_PROVIDER=gemini

# Google AI Studio (free tier)
GEMINI_API_KEY=your-gemini-api-key
# Optional overrides (defaults set in configs/settings.py)
# GEMINI_GENERATION_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# Anthropic / Claude (https://console.anthropic.com). Required when
# LLM_PROVIDER=claude and for the CV-enhance endpoint.
ANTHROPIC_API_KEY=your-anthropic-api-key
# CLAUDE_GENERATION_MODEL=claude-opus-4-8

# Adzuna (https://developer.adzuna.com - free)
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# CORS
FRONTEND_URL=http://localhost:3000

# PDF rendering (Prompt 7)
# Local: install Typst (https://github.com/typst/typst/releases) and keep "typst"
# Render: ./bin/typst (installed by build.sh)
TYPST_BIN=typst
