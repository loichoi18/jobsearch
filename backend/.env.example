# Supabase (Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Project Settings -> API -> JWT Secret (used to verify user tokens locally)
SUPABASE_JWT_SECRET=your-jwt-secret

# Google AI Studio (free tier)
GEMINI_API_KEY=your-gemini-api-key
# Optional overrides (defaults set in configs/settings.py)
# GEMINI_GENERATION_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# Adzuna (https://developer.adzuna.com - free)
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# CORS
FRONTEND_URL=http://localhost:3000

# PDF rendering (Prompt 7)
# Local: install Typst (https://github.com/typst/typst/releases) and keep "typst"
# Render: ./bin/typst (installed by build.sh)
TYPST_BIN=typst
